            task.defer(function()
                if popup.Visible then
                    local abs=popup.AbsolutePosition; local sz=popup.AbsoluteSize
                    local mp=UserInputService:GetMouseLocation()
                    if mp.X<abs.X or mp.X>abs.X+sz.X or mp.Y<abs.Y or mp.Y>abs.Y+sz.Y then
                        popup.Visible=false
                    end
                end
            end)
        end
    end)

    return wrapper
end

-- Collapsible Player List
local function makePlayerList(parent, title, order, onSelect)
    local wrapper=Instance.new("Frame")
    wrapper.Size=UDim2.new(1,0,0,30); wrapper.BackgroundColor3=Color3.fromRGB(18,18,28)
    wrapper.BorderSizePixel=0; wrapper.LayoutOrder=order; wrapper.ClipsDescendants=true
    wrapper.Parent=parent
    Instance.new("UICorner",wrapper).CornerRadius=UDim.new(0,6)
    local st=Instance.new("UIStroke",wrapper); st.Color=Color3.fromRGB(45,45,65); st.Thickness=1

    local headerBtn=Instance.new("TextButton",wrapper)
    headerBtn.Size=UDim2.new(1,0,0,30); headerBtn.BackgroundTransparency=1; headerBtn.Text=""

    local arrowLbl=Instance.new("TextLabel",headerBtn)
    arrowLbl.Text="▶  "..title; arrowLbl.Size=UDim2.new(1,-90,1,0); arrowLbl.Position=UDim2.new(0,8,0,0)
    arrowLbl.BackgroundTransparency=1; arrowLbl.TextColor3=Color3.fromRGB(150,150,210)
    arrowLbl.TextSize=12; arrowLbl.Font=Enum.Font.GothamBold; arrowLbl.TextXAlignment=Enum.TextXAlignment.Left

    local refreshBtn=Instance.new("TextButton",wrapper)
    refreshBtn.Size=UDim2.new(0,66,0,20); refreshBtn.Position=UDim2.new(1,-74,0.5,-10)
    refreshBtn.BackgroundColor3=Color3.fromRGB(35,35,55); refreshBtn.BorderSizePixel=0
    refreshBtn.Text="↻ Refresh"; refreshBtn.TextColor3=Color3.fromRGB(140,140,190)
    refreshBtn.TextSize=10; refreshBtn.Font=Enum.Font.Gotham; refreshBtn.ZIndex=5
    Instance.new("UICorner",refreshBtn).CornerRadius=UDim.new(0,4)

    -- Scrollable list inside collapse
    local MAX_VISIBLE_ROWS = 5
    local ROW_H            = 28

    local listScroll=Instance.new("ScrollingFrame",wrapper)
    listScroll.Position=UDim2.new(0,4,0,32); listScroll.Size=UDim2.new(1,-8,0,0)
    listScroll.BackgroundTransparency=1; listScroll.BorderSizePixel=0
    listScroll.ScrollBarThickness=3; listScroll.ScrollBarImageColor3=Color3.fromRGB(80,80,130)
    listScroll.CanvasSize=UDim2.new(0,0,0,0); listScroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
    listScroll.ScrollingDirection=Enum.ScrollingDirection.Y
    listScroll.ElasticBehavior=Enum.ElasticBehavior.Never
    listScroll.ClipsDescendants=true

    local lLayout=Instance.new("UIListLayout",listScroll)
    lLayout.SortOrder=Enum.SortOrder.LayoutOrder; lLayout.Padding=UDim.new(0,2)
    local lPad=Instance.new("UIPadding",listScroll)
    lPad.PaddingTop=UDim.new(0,2); lPad.PaddingBottom=UDim.new(0,2)
    lPad.PaddingLeft=UDim.new(0,2); lPad.PaddingRight=UDim.new(0,2)

    local expanded=false
    local selectedPlayer=nil
    local selectedBtn_=nil

    local function recalcHeight()
        task.wait()
        if expanded then
            local playerCount = #Players:GetPlayers()-1
            local visRows     = math.min(playerCount, MAX_VISIBLE_ROWS)
            local scrollH     = math.max(visRows * (ROW_H+2) + 4, 30)
            listScroll.Size   = UDim2.new(1,-8,0,scrollH)
            wrapper.Size      = UDim2.new(1,0,0,34+scrollH+4)
        else
            listScroll.Size   = UDim2.new(1,-8,0,0)
            wrapper.Size      = UDim2.new(1,0,0,30)
        end
    end

    local function populate()
        for _,ch in ipairs(listScroll:GetChildren()) do
            if ch:IsA("TextButton") then ch:Destroy() end
        end
        selectedPlayer=nil; selectedBtn_=nil
        if onSelect then onSelect(nil) end
        local idx=0
        for _,p in ipairs(Players:GetPlayers()) do
            if p==LocalPlayer then continue end
            local pb=Instance.new("TextButton",listScroll)
            pb.Size=UDim2.new(1,0,0,ROW_H); pb.BackgroundColor3=Color3.fromRGB(28,28,44)
            pb.BorderSizePixel=0; pb.Text=p.Name; pb.TextColor3=Color3.fromRGB(190,190,190)
            pb.TextSize=11; pb.Font=Enum.Font.Gotham; pb.LayoutOrder=idx
            Instance.new("UICorner",pb).CornerRadius=UDim.new(0,4)
            pb.MouseButton1Click:Connect(function()
                if selectedBtn_ then
                    selectedBtn_.BackgroundColor3=Color3.fromRGB(28,28,44)
                    selectedBtn_.TextColor3=Color3.fromRGB(190,190,190)
                end
                if selectedPlayer==p then
                    selectedPlayer=nil; selectedBtn_=nil
                    if onSelect then onSelect(nil) end
                else
                    selectedPlayer=p; selectedBtn_=pb
                    pb.BackgroundColor3=Color3.fromRGB(55,80,200)
                    pb.TextColor3=Color3.fromRGB(255,255,255)
                    if onSelect then onSelect(p) end
                end
            end)
            idx=idx+1
        end
        recalcHeight()
    end

    headerBtn.MouseButton1Click:Connect(function()
        expanded=not expanded
        arrowLbl.Text=(expanded and "▼  " or "▶  ")..title
        if expanded then populate() else recalcHeight() end
    end)
    refreshBtn.MouseButton1Click:Connect(function()
        if expanded then populate() end
    end)

    return wrapper, function() return selectedPlayer end
end

