-- ══════════════════════════════════════════
--   KEYBINDS (hard chat guard on every bind)
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input,gpe)
    if isChatFocused() then return end
    if gpe then return end

    if input.KeyCode==Enum.KeyCode.RightShift then
        Main.Visible=not Main.Visible

    elseif input.KeyCode==Enum.KeyCode.Z then
        State.esp.enabled=not State.esp.enabled
        setESPUI(State.esp.enabled)

    elseif input.KeyCode==Enum.KeyCode.F then
        local tp=State.tp.selectedPlayer
        local tpr=tp and getRoot(tp)
        local lpr=getRoot(LocalPlayer)
        if tpr and lpr then lpr.CFrame=tpr.CFrame+Vector3.new(0,3,0) end

    elseif input.KeyCode==Enum.KeyCode.H then
        State.tp.autoFollow=not State.tp.autoFollow
        setAutoFollowUI(State.tp.autoFollow)

    elseif input.KeyCode==Enum.KeyCode.G then
        local nv=not State.fly.enabled
        setFlyUI(nv); applyFly(nv)

    elseif input.KeyCode==Enum.KeyCode.E then
        State.aimlock.enabled=not State.aimlock.enabled
        setAimlockUI(State.aimlock.enabled)
        if State.aimlock.enabled then startAimlockLoop() else stopAimlockLoop() end

    elseif input.KeyCode==Enum.KeyCode.N then
        local nearest=getNearestPlayer()
        if nearest then
            State.aimlock.selectedPlayer=nearest
            State.aimlock.enabled=true
            setAimlockUI(true)
            startAimlockLoop()
        end
    end
end)

