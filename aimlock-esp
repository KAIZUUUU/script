    -- inner scroll for the popup list
    local popScroll=Instance.new("ScrollingFrame",popup)
    popScroll.Size=UDim2.new(1,-2,1,-4); popScroll.Position=UDim2.new(0,1,0,2)
    popScroll.BackgroundTransparency=1; popScroll.BorderSizePixel=0
    popScroll.ScrollBarThickness=3; popScroll.ScrollBarImageColor3=Color3.fromRGB(80,80,130)
    popScroll.CanvasSize=UDim2.new(0,0,0,0); popScroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
    popScroll.ScrollingDirection=Enum.ScrollingDirection.Y
    popScroll.ElasticBehavior=Enum.ElasticBehavior.Never
    popScroll.ZIndex=51

    local pLayout=Instance.new("UIListLayout",popScroll)
    pLayout.SortOrder=Enum.SortOrder.LayoutOrder; pLayout.Padding=UDim.new(0,2)
    local pPad=Instance.new("UIPadding",popScroll)
    pPad.PaddingTop=UDim.new(0,2); pPad.PaddingBottom=UDim.new(0,2)
    pPad.PaddingLeft=UDim.new(0,2); pPad.PaddingRight=UDim.new(0,2)

    for idx,partName in ipairs(PARTS) do
        local opt=Instance.new("TextButton",popScroll)
        opt.Size=UDim2.new(1,0,0,ITEM_H); opt.BackgroundColor3=Color3.fromRGB(35,35,58)
        opt.BorderSizePixel=0; opt.Text=partName; opt.TextColor3=Color3.fromRGB(190,190,210)
        opt.TextSize=11; opt.Font=Enum.Font.Gotham; opt.LayoutOrder=idx; opt.ZIndex=52
        Instance.new("UICorner",opt).CornerRadius=UDim.new(0,4)
        opt.MouseEnter:Connect(function() opt.BackgroundColor3=Color3.fromRGB(55,55,90) end)
        opt.MouseLeave:Connect(function() opt.BackgroundColor3=Color3.fromRGB(35,35,58) end)
