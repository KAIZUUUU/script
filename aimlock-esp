    minusBtn.MouseButton1Click:Connect(function()
        val=math.max(minV,val-step); valLbl.Text=tostring(val)
        if onChange then onChange(val) end
    end)
    plusBtn.MouseButton1Click:Connect(function()
        val=math.min(maxV,val+step); valLbl.Text=tostring(val)
        if onChange then onChange(val) end
    end)
    return row
end

