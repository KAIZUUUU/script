local ESPData={}

local function removeESPPlayer(player)
    local d=ESPData[player]; if not d then return end
    pcall(function() if d.highlight then d.highlight:Destroy() end end)
    pcall(function() if d.billboard then d.billboard:Destroy() end end)
    pcall(function() if d.line      then d.line:Remove()       end end)
    ESPData[player]=nil
end

local function buildESPPlayer(player)
    if player==LocalPlayer then return end
    removeESPPlayer(player)
    local data={}

    -- Highlight chams
    local hl=Instance.new("Highlight")
    hl.Name="AxiomHL_"..player.Name
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillTransparency=0.45; hl.OutlineTransparency=0
    data.highlight=hl

    -- BillboardGui parented to PlayerGui so it always renders
    -- Adornee is set dynamically each tick
    local bb=Instance.new("BillboardGui")
    bb.Name="AxiomBB_"..player.Name
    bb.AlwaysOnTop=true
    bb.LightInfluence=0
    bb.MaxDistance=1500
    bb.Size=UDim2.new(0,120,0,60)
    bb.StudsOffsetWorldSpace=Vector3.new(0,3,0)
    bb.ResetOnSpawn=false
    bb.ClipsDescendants=false
    -- Parent to PlayerGui so it's always in the render tree
    pcall(function() bb.Parent=LocalPlayer.PlayerGui end)
    if not bb.Parent then bb.Parent=ScreenGui end

    -- Username label
    local nameLbl=Instance.new("TextLabel",bb)
    nameLbl.Name="NameLbl"
    nameLbl.Size=UDim2.new(1,0,0,0); nameLbl.AutomaticSize=Enum.AutomaticSize.Y
    nameLbl.Position=UDim2.new(0,0,0,0)
    nameLbl.BackgroundTransparency=1
    nameLbl.TextStrokeTransparency=0.35; nameLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    nameLbl.Font=Enum.Font.GothamBold
    nameLbl.TextXAlignment=Enum.TextXAlignment.Center
    nameLbl.Text=""; nameLbl.TextScaled=false

    -- Team label
    local teamLbl=Instance.new("TextLabel",bb)
    teamLbl.Name="TeamLbl"
    teamLbl.Size=UDim2.new(1,0,0,0); teamLbl.AutomaticSize=Enum.AutomaticSize.Y
    teamLbl.Position=UDim2.new(0,0,0.45,0)
    teamLbl.BackgroundTransparency=1
    teamLbl.TextStrokeTransparency=0.35; teamLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    teamLbl.Font=Enum.Font.Gotham
    teamLbl.TextXAlignment=Enum.TextXAlignment.Center
    teamLbl.Text=""; teamLbl.TextScaled=false

    -- Distance label
    local distLbl=Instance.new("TextLabel",bb)
    distLbl.Name="DistLbl"
    distLbl.Size=UDim2.new(1,0,0,0); distLbl.AutomaticSize=Enum.AutomaticSize.Y
    distLbl.Position=UDim2.new(0,0,0.72,0)
    distLbl.BackgroundTransparency=1
    distLbl.TextStrokeTransparency=0.35; distLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    distLbl.Font=Enum.Font.Gotham
    distLbl.TextXAlignment=Enum.TextXAlignment.Center
    distLbl.Text=""; distLbl.TextScaled=false

    data.billboard=bb
    data.nameLbl=nameLbl
    data.teamLbl=teamLbl
    data.distLbl=distLbl

    -- Drawing line
    local line=Drawing.new("Line")
    line.Thickness=1.5; line.Transparency=0.25; line.ZIndex=3; line.Visible=false
    data.line=line

    ESPData[player]=data
end

local function espTick()
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer then continue end
        if not ESPData[p] then buildESPPlayer(p) end
        local d=ESPData[p]
        local char=p.Character
        local myChar=LocalPlayer.Character

        if not State.esp.enabled or not char or not myChar then
            if d.highlight then d.highlight.Enabled=false end
            if d.billboard then d.billboard.Enabled=false end
            if d.line      then d.line.Visible=false      end
            continue
        end

        local root=getRoot(p)
        local myRoot=getRoot(LocalPlayer)
        local head=getHead(p)
        if not root or not myRoot then
            if d.highlight then d.highlight.Enabled=false end
            if d.billboard then d.billboard.Enabled=false end
            if d.line      then d.line.Visible=false      end
            continue
        end

        local tc=getTeamColor(p)
        local pastel=pastelOf(tc)
        local dist=getStuds(p)
        local tname=getTeamName(p)

        -- Highlight
        if not d.highlight.Parent then
            d.highlight.Adornee=char; d.highlight.Parent=char
        end
        d.highlight.FillColor=pastel; d.highlight.OutlineColor=tc; d.highlight.Enabled=true

        -- Billboard: dynamic scale based on distance
        local clamped=math.clamp(dist,8,300)
        local t=1-(clamped/300)                      -- 0=far, 1=close
        local bW=math.floor(110+t*110)               -- 110-220px wide
        local bH=math.floor(55+t*55)                 -- 55-110px tall
        local tSizeName=math.floor(10+t*10)          -- 10-20
        local tSizeSmall=math.floor(8+t*8)           -- 8-16

        d.billboard.Adornee=head or root
        d.billboard.Size=UDim2.new(0,bW,0,bH)
        d.billboard.Enabled=true

        d.nameLbl.Text=p.Name
        d.nameLbl.TextColor3=Color3.fromRGB(255,255,255)
        d.nameLbl.TextSize=tSizeName

        d.teamLbl.Text="["..tname.."]"
        d.teamLbl.TextColor3=tc
        d.teamLbl.TextSize=tSizeSmall

        d.distLbl.Text=dist.." studs"
        d.distLbl.TextColor3=Color3.fromRGB(200,200,200)
        d.distLbl.TextSize=tSizeSmall

        -- Line
        local myScreen,myVis=Camera:WorldToViewportPoint(myRoot.Position)
        local theirScreen,thVis=Camera:WorldToViewportPoint(root.Position)
        if myVis and thVis then
            d.line.From=Vector2.new(myScreen.X,myScreen.Y)
            d.line.To=Vector2.new(theirScreen.X,theirScreen.Y)
            d.line.Color=tc; d.line.Visible=true
        else
            d.line.Visible=false
        end
    end

    for p in pairs(ESPData) do
        if not p or not p.Parent then removeESPPlayer(p) end
    end
end

