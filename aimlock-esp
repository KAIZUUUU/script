local function isChatFocused()
    return UserInputService:GetFocusedTextBox() ~= nil
end

local function getRoot(player)
    local c = player and player.Character
    if not c then return nil end
    return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")
end

local function getHead(player)
    local c = player and player.Character
    return c and c:FindFirstChild("Head")
end

local function getPart(player, partName)
    local c = player and player.Character
    if not c then return nil end
    local map = {
        ["Head"]      = "Head",
        ["Torso"]     = "HumanoidRootPart",
        ["Left Arm"]  = "Left Arm",
        ["Right Arm"] = "Right Arm",
        ["Left Leg"]  = "Left Leg",
        ["Right Leg"] = "Right Leg",
    }
    local rn = map[partName] or partName
    return c:FindFirstChild(rn)
        or c:FindFirstChild("Upper"..rn)
        or c:FindFirstChild(rn:gsub(" ",""))
        or c:FindFirstChild("HumanoidRootPart")
end

local function getTeamColor(player)
    return (player.Team and player.TeamColor.Color) or Color3.fromRGB(255,255,255)
end

local function getTeamName(player)
    return (player.Team and player.Team.Name) or "No Team"
end

local function pastelOf(c)
    return Color3.new((c.R+1)/2,(c.G+1)/2,(c.B+1)/2)
end

local function getStuds(player)
    local r1 = getRoot(LocalPlayer)
    local r2 = getRoot(player)
    if r1 and r2 then return math.floor((r1.Position-r2.Position).Magnitude) end
    return 0
end

local function getNearestPlayer()
    local myRoot = getRoot(LocalPlayer); if not myRoot then return nil end
    local nearest, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local r = getRoot(p)
        if r then
            local d = (myRoot.Position - r.Position).Magnitude
            if d < bestDist then bestDist = d; nearest = p end
        end
    end
    return nearest
end

-- ══════════════════════════════════════════
--       AIMLOCK CORE (STABLE LOCKED)
-- ══════════════════════════════════════════
local AIMLOCK_PRIORITY = Enum.RenderPriority.Camera.Value + 1

local function startAimlockLoop()
    pcall(function() RunService:UnbindFromRenderStep("AxiomAimlock") end)
    RunService:BindToRenderStep("AxiomAimlock", AIMLOCK_PRIORITY, function()
        if not State.aimlock.enabled then return end
        local ap = State.aimlock.selectedPlayer; if not ap then return end
        local part = getPart(ap, State.aimlock.targetPart); if not part then return end
        if Camera.CameraType ~= Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Scriptable
            State.aimlock.lockedCamType = true
        end
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
    end)
end

local function stopAimlockLoop()
    pcall(function() RunService:UnbindFromRenderStep("AxiomAimlock") end)
    if State.aimlock.lockedCamType then
        Camera.CameraType = Enum.CameraType.Custom
        State.aimlock.lockedCamType = false
    end
end

