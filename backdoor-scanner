    label.Size = UDim2.new(1, -10, 0, 25)
    label.BackgroundColor3 = isBackdoor and Color3.fromRGB(100, 30, 30) or Color3.fromRGB(30, 30, 40)
    label.Text = text
    label.TextColor3 = isBackdoor and Color3.fromRGB(255, 150, 150) or Color3.fromRGB(200, 200, 200)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
