local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")

local BACKEND_URL = "enter-url"

local function urlEncode(str)
    local result = ""
    for i = 1, #str do
        local c = string.sub(str, i, i)
        if c:match("[a-zA-Z0-9%-._~]") then
            result = result .. c
        else
            result = result .. string.format("%%%02X", string.byte(c))
        end
    end
    return result
end

local function scanScript(scriptContent, scriptName, callback)
    local encoded = urlEncode(scriptContent)
    local url = BACKEND_URL .. "?script=" .. encoded
    
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        local result = HttpService:JSONDecode(response)
        callback(result, scriptName)
    else
        callback({verdict = "error", reason = "HTTP failed: " .. tostring(response)}, scriptName)
    end
end

local function getAllScripts()
    local scripts = {}
    local visited = {}
    
    local containers = {
        game,
        workspace,
        game:GetService("ReplicatedStorage"),
        game:GetService("ServerStorage"),
        game:GetService("ServerScriptService"),
        game:GetService("StarterGui"),
        game:GetService("StarterPack"),
        game:GetService("StarterPlayer"),
        game:GetService("StarterPlayer").StarterPlayerScripts,
        game:GetService("StarterPlayer").StarterCharacterScripts,
        game:GetService("Players"),
        game:GetService("Lighting"),
        game:GetService("SoundService"),
        game:GetService("Chat"),
        game:GetService("TextService"),
        game:GetService("TeleportService"),
        game:GetService("CoreGui"),
        game:GetService("CorePackages"),
        game:GetService("HttpService"),
        game:GetService("RunService"),
        game:GetService("UserInputService"),
        game:GetService("ContextMenuService"),
        game:GetService("GuiService"),
        game:GetService("MarketplaceService"),
        game:GetService("MessagingService"),
        game:GetService("PathfindingService"),
        game:GetService("PhysicsService"),
        game:GetService("PointsService"),
        game:GetService("PolicyService"),
        game:GetService("ProximityPromptService"),
        game:GetService("Selection"),
        game:GetService("Stats"),
        game:GetService("TestService"),
        game:GetService("Teams"),
        game:GetService("Terrain"),
        game:GetService("VirtualInputManager"),
        game:GetService("VoiceChatService"),
        game:GetService("CollectionService"),
        game:GetService("ChangeHistoryService"),
        game:GetService("AssetService"),
        game:GetService("BadgeService"),
        game:GetService("AnalyticsService"),
        game:GetService("AdService"),
        game:GetService("SocialService"),
    }
    
    local function deepSearch(instance, path)
        if not instance or visited[instance] then return end
        visited[instance] = true
        
        if instance:IsA("Script") or instance:IsA("LocalScript") or instance:IsA("ModuleScript") then
            if instance.Source and instance.Source ~= "" then
                table.insert(scripts, {
                    name = path,
                    source = instance.Source,
                    class = instance.ClassName,
                    parent = instance.Parent and instance.Parent.Name or "nil"
                })
            end
        end
        
        if instance:IsA("RemoteEvent") or instance:IsA("RemoteFunction") or instance:IsA("UnreliableRemoteEvent") then
            table.insert(scripts, {
                name = path .. " [REMOTE]",
                source = "-- Remote object found. Potential backdoor entry point.\n-- Listen for: " .. instance.Name,
                class = instance.ClassName,
                parent = instance.Parent and instance.Parent.Name or "nil",
                isRemote = true
            })
        end
        
        local success, children = pcall(function()
            return instance:GetChildren()
        end)
        
        if success and children then
            for _, child in pairs(children) do
                local newPath = path .. "/" .. child.Name
                deepSearch(child, newPath)
            end
        end
    end
    
    for _, container in pairs(containers) do
        if container then
            local success, err = pcall(function()
                deepSearch(container, container.ClassName .. ":" .. (container.Name or "ROOT"))
            end)
            if not success then
                print("[!] Error scanning " .. tostring(container) .. ": " .. tostring(err))
            end
        end
    end
    
    local player = LocalPlayer
    if player then
        if player.Character then
            deepSearch(player.Character, "Player.Character")
        end
        if player.PlayerGui then
            deepSearch(player.PlayerGui, "Player.PlayerGui")
        end
        if player.Backpack then
            deepSearch(player.Backpack, "Player.Backpack")
        end
    end
    
    return scripts
end

