    label.Parent = resultsBox
    
    resultsBox.CanvasSize = UDim2.new(0, 0, 0, resultsList.AbsoluteContentSize.Y)
end

local function clearResults()
    for _, child in pairs(resultsBox:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
end

local function startDeepScan()
    clearResults()
    statusLabel.Text = "Collecting ALL scripts and remotes..."
    addResult("Starting ultra-deep scan...", false)
    
    local allScripts = getAllScripts()
    local total = #allScripts
    
    if total == 0 then
        statusLabel.Text = "No scripts or remotes found."
        addResult("No scripts or remote objects found in this game.", false)
        addResult("The game may have protected scripts or be completely scriptless.", false)
        return
    end
    
    statusLabel.Text = string.format("Found %d scripts/remotes. Scanning with AI...", total)
    addResult(string.format("Found %d scripts and remote objects to analyze.", total), false)
    
    local backdoorCount = 0
    local processed = 0
    
    for _, scriptData in ipairs(allScripts) do
        processed = processed + 1
        local percent = (processed / total) * 100
        progressFill.Size = UDim2.new(percent / 100, 0, 1, 0)
        progressText.Text = string.format("%.1f%% (%d/%d)", percent, processed, total)
        statusLabel.Text = string.format("Scanning: %s", scriptData.name)
        
        scanScript(scriptData.source, scriptData.name, function(result, name)
            if result.verdict == "malicious" or result.verdict == "suspicious" then
                backdoorCount = backdoorCount + 1
                addResult(string.format("[%s] %s - %s", 
                    string.upper(result.verdict), 
                    name, 
                    result.reason), 
                    true)
            elseif scriptData.isRemote then
                addResult(string.format("[REMOTE] %s - Potential backdoor entry point", name), true)
                backdoorCount = backdoorCount + 1
            else
                addResult(string.format("[SAFE] %s - %s", name, result.reason or "No issues"), false)
            end
        end)
        
        task.wait(0.05)
    end
    
    progressFill.Size = UDim2.new(1, 0, 1, 0)
    progressText.Text = "100%"
    statusLabel.Text = string.format("Scan complete! Found %d potential backdoor(s).", backdoorCount)
    addResult(string.format("\n=== SCAN COMPLETE: %d POTENTIAL BACKDOOR(S) FOUND ===\n", backdoorCount), backdoorCount > 0)
end

